rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Kullanıcı verilerine sadece kendi user'lar erişebilir
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
    
    // Kullanıcı notları
    match /users/{userId}/notes/{noteId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
